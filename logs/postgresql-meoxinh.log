	LANGUAGE sql
	IMMUTABLE
	PARALLEL SAFE
	AS $$
	  SELECT translate(
	    lower(coalesce($1, '')),
	    'áàảãạăắằẳẵặâấầẩẫậéèẻẽẹêếềểễệíìỉĩịóòỏõọôốồổỗộơớờởỡợúùủũụưứừửữựýỳỷỹỵđ',
	    'aaaaaaaaaaaaaaaaaeeeeeeeeeeeiiiiiooooooooooooooooouuuuuuuuuuuyyyyyd'
	  )
	$$;
	
	CREATE INDEX IF NOT EXISTS "Customer_search_vi_idx"
	  ON "Customer" (vi_unaccent(coalesce("name", '') || ' ' || coalesce("phone", '') || ' ' || coalesce("email", '') || ' ' || coalesce("note", '')));
	
	CREATE INDEX IF NOT EXISTS "Booking_search_vi_idx"
	  ON "Booking" (vi_unaccent(coalesce("customerName", '') || ' ' || coalesce("packageName", '') || ' ' || coalesce("categoryName", '') || ' ' || coalesce("title", '') || ' ' || coalesce("note", '')));
	
	CREATE INDEX IF NOT EXISTS "Transaction_search_vi_idx"
	  ON "Transaction" (vi_unaccent(coalesce("title", '') || ' ' || coalesce("note", '') || ' ' || coalesce("amount"::text, '')));
	
	CREATE INDEX IF NOT EXISTS "Project_search_vi_idx"
	  ON "Project" (vi_unaccent(coalesce("code", '') || ' ' || coalesce("name", '') || ' ' || coalesce("note", '')));
	
	CREATE INDEX IF NOT EXISTS "Package_search_vi_idx"
	  ON "Package" (vi_unaccent(coalesce("name", '') || ' ' || coalesce("description", '') || ' ' || coalesce("includes", '')));
	
