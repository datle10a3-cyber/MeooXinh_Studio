2026-05-06 22:15:02.815 +07 [21448] STATEMENT:  -- Search helpers for long-term PostgreSQL usage.
	CREATE EXTENSION IF NOT EXISTS unaccent;
	CREATE EXTENSION IF NOT EXISTS pg_trgm;
	
	CREATE OR REPLACE FUNCTION immutable_unaccent(text)
	RETURNS text
	LANGUAGE sql
	IMMUTABLE
	PARALLEL SAFE
	AS $$
	  SELECT public.unaccent('public.unaccent', $1)
	$$;
	
	CREATE INDEX IF NOT EXISTS "Customer_search_unaccent_idx"
	  ON "Customer" USING gin (immutable_unaccent(lower(coalesce("name", '') || ' ' || coalesce("phone", '') || ' ' || coalesce("email", '') || ' ' || coalesce("note", ''))) gin_trgm_ops);
	
	CREATE INDEX IF NOT EXISTS "Booking_search_unaccent_idx"
	  ON "Booking" USING gin (immutable_unaccent(lower(coalesce("customerName", '') || ' ' || coalesce("packageName", '') || ' ' || coalesce("categoryName", '') || ' ' || coalesce("title", '') || ' ' || coalesce("note", ''))) gin_trgm_ops);
	
	CREATE INDEX IF NOT EXISTS "Transaction_search_unaccent_idx"
	  ON "Transaction" USING gin (immutable_unaccent(lower(coalesce("title", '') || ' ' || coalesce("note", '') || ' ' || coalesce("amount"::text, ''))) gin_trgm_ops);
	
	CREATE INDEX IF NOT EXISTS "Project_search_unaccent_idx"
	  ON "Project" USING gin (immutable_unaccent(lower(coalesce("code", '') || ' ' || coalesce("name", '') || ' ' || coalesce("note", ''))) gin_trgm_ops);
	
	CREATE INDEX IF NOT EXISTS "Package_search_unaccent_idx"
	  ON "Package" USING gin (immutable_unaccent(lower(coalesce("name", '') || ' ' || coalesce("description", '') || ' ' || coalesce("includes", ''))) gin_trgm_ops);
	
