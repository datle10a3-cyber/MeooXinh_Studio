{
  "name": "thuthao_studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/dev-studio.ps1",
    "dev:next": "next dev",
    "dev:studio": "powershell -ExecutionPolicy Bypass -File scripts/dev-studio.ps1",
    "deploy:check": "node scripts/deploy-check.js && prisma validate && next build",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:up": "powershell -ExecutionPolicy Bypass -File scripts/start-postgres.ps1",
    "db:down": "powershell -ExecutionPolicy Bypass -File scripts/stop-postgres.ps1",
    "db:migrate": "prisma migrate deploy",
    "db:dev": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:backup": "powershell -ExecutionPolicy Bypass -File scripts/backup-postgres.ps1",
    "db:backup:schedule": "powershell -ExecutionPolicy Bypass -File scripts/install-daily-backup.ps1",
    "db:cleanup-trash": "powershell -ExecutionPolicy Bypass -File scripts/cleanup-soft-deleted.ps1",
    "db:archive-year": "powershell -ExecutionPolicy Bypass -File scripts/archive-year.ps1",
    "test:smoke": "powershell -ExecutionPolicy Bypass -File scripts/smoke-tests.ps1",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/nodemailer": "^8.0.0",
    "@types/web-push": "^3.6.4",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "nextjs-toploader": "^3.9.17",
    "nodemailer": "^8.0.7",
    "openai": "^6.35.0",
    "prisma": "^5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
